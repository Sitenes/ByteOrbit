@{
  ViewData["Title"] = "بایت اوربیت - کارگاه رباتیک";
  Layout = null;
}
<!DOCTYPE html>
<html lang="fa" dir="rtl">

<head>

  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
  <meta name="description" content="بایت اوربیت - کارگاه تخصصی آموزش رباتیک، الکترونیک و برنامه‌نویسی در اصفهان">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@100;200;300;400;500;600;700;800;900&display=swap"
        rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Vazirmatn:wght@100;200;300;400;500;600;700;800;900&display=swap"
        rel="stylesheet">

  <title>بایت اوربیت | کارگاه رباتیک - آموزش برنامه‌نویسی، الکترونیک و رباتیک</title>

  <!-- Bootstrap core CSS -->
  <link href="vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">

  <!-- Additional CSS Files -->
  <link rel="stylesheet" href="assets/css/fontawesome.css">
  <link rel="stylesheet" href="assets/css/templatemo-scholar.css">
  <link rel="stylesheet" href="assets/css/owl.css">
  <link rel="stylesheet" href="assets/css/animate.css">
  <link rel="stylesheet" href="https://unpkg.com/swiper@7/swiper-bundle.min.css" />

  <style>
      /* ===== ORBIT RTL & PERSIAN FONT OVERRIDE ===== */
      *,
      body,
      html {
        font-family: 'Vazirmatn', 'Poppins', sans-serif !important;
      }

      body {
        direction: rtl;
      }

      /* ===== COLOR PALETTE OVERRIDE ===== */
      :root {
        --orbit-dark: #007171;
        --orbit-mid: #006868;
        --orbit-base: #008d8d;
        --orbit-light: #00bcbc;
        --orbit-pale: #eef8fa;
        --orbit-orange: #ed7d31;
        --orbit-peach: #f5be98;
      }

      ::selection {
        background: var(--orbit-base);
        color: #fff;
      }

      ::-moz-selection {
        background: var(--orbit-base);
        color: #fff;
      }

      /* ===== PRELOADER ===== */
      .preloader-inner .dot,
      .preloader-inner .dots span {
        background: var(--orbit-light) !important;
      }

      /* ===== HEADER ===== */
      .background-header {
        background-color: var(--orbit-dark) !important;
      }

      .header-area .main-nav .logo h1 {
        color: #fff;
        font-size: 26px;
        letter-spacing: 1px;
      }

      .header-area .main-nav .nav li a {
        color: #fff;
        font-weight: 500;
      }

      .header-area .main-nav .nav li a:hover,
      .header-area .main-nav .nav li a.active {
        color: var(--orbit-peach) !important;
        border-bottom: 2px solid var(--orbit-orange);
      }

      .background-header .main-nav .nav li a {
        color: #fff;
      }

      .background-header .main-nav .nav li a:hover,
      .background-header .main-nav .nav li a.active {
        color: var(--orbit-peach) !important;
      }

      .header-area .main-nav #search input {
        background: rgba(255, 255, 255, 0.15);
        color: #fff;
        border-color: rgba(255, 255, 255, 0.3);
      }

      .header-area .main-nav #search input::placeholder {
        color: rgba(255, 255, 255, 0.7);
      }

      .header-area .main-nav #search i {
        color: rgba(255, 255, 255, 0.8);
      }

      .orbit-register-btn {
        background: var(--orbit-orange) !important;
        color: #fff !important;
        border-radius: 25px !important;
        padding: 6px 20px !important;
        font-weight: 600 !important;
        transition: all .3s !important;
      }

      .orbit-register-btn:hover {
        background: var(--orbit-peach) !important;
        color: var(--orbit-dark) !important;
        border-bottom: none !important;
      }

      /* ===== BANNER ===== */
      .main-banner .item-1 {
        background-image: url('assets/images/banner-01.jpg');
        background-color: var(--orbit-dark);
      }

      .main-banner .item-2 {
        background-image: url('assets/images/banner-02.jpg');
        background-color: var(--orbit-mid);
      }

      .main-banner .item-3 {
        background-image: url('assets/images/banner-03.jpg');
        background-color: var(--orbit-base);
      }

      .main-banner .item {
        background-color: var(--orbit-dark);
        min-height: 600px;
      }

      .main-banner .item::before {
        background: linear-gradient(135deg, rgba(0, 113, 113, 0.92) 0%, rgba(0, 188, 188, 0.75) 100%);
      }

      .main-banner .item span.category {
        background: var(--orbit-orange);
        color: #fff;
        font-size: 13px;
        border-radius: 20px;
        padding: 5px 18px;
        font-weight: 600;
      }

      .main-banner .item h2 {
        font-size: 42px;
        line-height: 58px;
        color: #fff;
      }

      .main-banner .item p {
        color: rgba(255, 255, 255, 0.9);
        font-size: 15px;
      }

      .main-banner .item .buttons .main-button a {
        background: var(--orbit-orange);
        color: #fff;
        border-radius: 25px;
        padding: 12px 30px;
        height: auto;
        line-height: normal;
        font-weight: 600;
      }

      .main-banner .item .buttons .main-button a:hover {
        background: var(--orbit-peach);
        color: var(--orbit-dark);
      }

      .main-banner .item .buttons .icon-button a {
        color: #fff;
        font-size: 14px;
      }

      .main-banner .owl-nav .owl-prev i,
      .main-banner .owl-nav .owl-next i {
        background: var(--orbit-orange);
        color: #fff;
        border-color: var(--orbit-orange);
      }

      .main-banner .owl-nav .owl-prev i:hover,
      .main-banner .owl-nav .owl-next i:hover {
        background: var(--orbit-dark);
      }

      /* ===== SECTION HEADINGS ===== */
      .section-heading h6 {
        color: var(--orbit-orange) !important;
      }

      .section-heading h2 em {
        color: var(--orbit-base) !important;
      }

      /* ===== MAIN BUTTON ===== */
      .main-button a {
        background: var(--orbit-pale);
        color: var(--orbit-dark);
        border: 2px solid var(--orbit-base);
        font-weight: 600;
      }

      .main-button a:hover {
        background: var(--orbit-dark);
        color: #fff;
        border-color: var(--orbit-dark);
      }

      /* ===== SERVICES ===== */
      .services .service-item {
        border-radius: 16px;
        border: 2px solid transparent;
        transition: all .3s;
      }

      .services .service-item:hover {
        border-color: var(--orbit-light);
        transform: translateY(-5px);
        box-shadow: 0 15px 40px rgba(0, 188, 188, 0.15);
      }

      .services .service-item .icon {
        background: linear-gradient(135deg, var(--orbit-pale) 0%, #d4f0f0 100%);
        border-radius: 50%;
        width: 80px;
        height: 80px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
      }

      .services .service-item .icon i {
        font-size: 36px;
        color: var(--orbit-dark);
      }

      .services .service-item h4 {
        color: var(--orbit-dark);
        font-size: 18px;
      }

      /* ===== ABOUT ACCORDION ===== */
      .accordion-button:not(.collapsed) {
        background: var(--orbit-pale);
        color: var(--orbit-dark);
        box-shadow: none;
      }

      .accordion-button:focus {
        box-shadow: 0 0 0 3px rgba(0, 188, 188, 0.25);
      }

      h2.accordion-header button {
        color: var(--orbit-mid);
        font-weight: 600;
      }

      .accordion-item {
        border-color: rgba(0, 141, 141, 0.2) !important;
        border-radius: 10px !important;
        margin-bottom: 8px;
        overflow: hidden;
      }

      .accordion-button::after {
        filter: hue-rotate(160deg) saturate(2);
      }

      /* ===== COURSES ===== */
      .event_filter li a.is_active,
      .event_filter li a:hover {
        background: var(--orbit-dark) !important;
        color: #fff !important;
      }

      .events_item .thumb span.category {
        background: var(--orbit-base);
      }

      .events_item .thumb span.price {
        background: var(--orbit-orange);
      }

      .events_item:hover .thumb span.price {
        background: var(--orbit-dark);
      }

      .events_item:hover .down-content h4 {
        color: var(--orbit-base);
      }

      .course-level-badge {
        display: inline-block;
        background: var(--orbit-pale);
        color: var(--orbit-dark);
        border-radius: 12px;
        padding: 3px 12px;
        font-size: 12px;
        font-weight: 600;
        margin-bottom: 8px;
        border: 1px solid var(--orbit-light);
      }

      .course-terms {
        font-size: 12px;
        color: var(--orbit-base);
        font-weight: 600;
      }

      /* ===== FUN FACTS ===== */
      .fun-facts {
        background: linear-gradient(135deg, var(--orbit-dark) 0%, var(--orbit-base) 60%, var(--orbit-light) 100%) !important;
      }

      .fun-facts:before,
      .fun-facts:after {
        background: transparent !important;
      }

      .fun-facts h2,
      .fun-facts p {
        color: #fff !important;
      }

      .fun-facts h2::after {
        background: var(--orbit-orange) !important;
      }

      /* ===== PRICING SECTION ===== */
      .pricing-section {
        background: var(--orbit-pale);
        padding: 80px 0;
        margin-top: 80px;
      }

      .pricing-card {
        background: #fff;
        border-radius: 20px;
        padding: 35px 30px;
        box-shadow: 0 8px 30px rgba(0, 113, 113, 0.1);
        transition: all .3s;
        border: 2px solid transparent;
        height: 100%;
      }

      .pricing-card:hover {
        transform: translateY(-8px);
        border-color: var(--orbit-light);
        box-shadow: 0 20px 50px rgba(0, 188, 188, 0.2);
      }

      .pricing-card.featured {
        background: linear-gradient(135deg, var(--orbit-dark) 0%, var(--orbit-base) 100%);
        color: #fff;
        border-color: var(--orbit-orange);
      }

      .pricing-card.featured h3,
      .pricing-card.featured p,
      .pricing-card.featured li,
      .pricing-card.featured .price-amount {
        color: #fff !important;
      }

      .pricing-card.featured .pricing-badge {
        background: var(--orbit-orange);
      }

      .pricing-badge {
        background: var(--orbit-pale);
        color: var(--orbit-dark);
        border-radius: 20px;
        padding: 5px 15px;
        font-size: 13px;
        font-weight: 700;
        display: inline-block;
        margin-bottom: 15px;
      }

      .price-amount {
        font-size: 28px;
        font-weight: 800;
        color: var(--orbit-dark);
        line-height: 1.2;
      }

      .price-unit {
        font-size: 14px;
        color: #888;
        font-weight: 400;
      }

      .pricing-card.featured .price-unit {
        color: rgba(255, 255, 255, 0.8);
      }

      .pricing-features {
        list-style: none;
        padding: 0;
        margin: 20px 0;
      }

      .pricing-features li {
        padding: 6px 0;
        border-bottom: 1px solid rgba(0, 141, 141, 0.1);
        font-size: 14px;
      }

      .pricing-features li::before {
        content: "✓ ";
        color: var(--orbit-orange);
        font-weight: 700;
      }

      .pricing-card.featured .pricing-features li {
        border-bottom-color: rgba(255, 255, 255, 0.15);
      }

      .pricing-card.featured .pricing-features li::before {
        color: var(--orbit-peach);
      }

      .pricing-cta {
        display: block;
        text-align: center;
        background: var(--orbit-orange);
        color: #fff !important;
        border-radius: 25px;
        padding: 12px 25px;
        font-weight: 700;
        margin-top: 20px;
        transition: all .3s;
      }

      .pricing-cta:hover {
        background: var(--orbit-dark);
      }

      .pricing-card.featured .pricing-cta {
        background: #fff;
        color: var(--orbit-dark) !important;
      }

      .pricing-card.featured .pricing-cta:hover {
        background: var(--orbit-peach);
        color: var(--orbit-dark) !important;
      }

      /* ===== EQUIPMENT SECTION ===== */
      .equipment-section {
        padding: 80px 0;
      }

      .equipment-card {
        background: #fff;
        border-radius: 16px;
        padding: 30px;
        border: 2px solid var(--orbit-pale);
        transition: all .3s;
      }

      .equipment-card:hover {
        border-color: var(--orbit-light);
        box-shadow: 0 10px 30px rgba(0, 188, 188, 0.15);
      }

      .equipment-icon {
        font-size: 48px;
        color: var(--orbit-base);
        margin-bottom: 15px;
      }

      .equipment-price-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 8px 0;
        border-bottom: 1px dashed rgba(0, 141, 141, 0.2);
      }

      .equipment-price-buy {
        color: var(--orbit-dark);
        font-weight: 700;
      }

      .equipment-price-rent {
        color: var(--orbit-orange);
        font-weight: 600;
      }

      /* ===== GUARANTEE SECTION ===== */
      .guarantee-section {
        background: linear-gradient(135deg, var(--orbit-pale) 0%, #d4f0f0 100%);
        padding: 80px 0;
      }

      .guarantee-card {
        background: #fff;
        border-radius: 16px;
        padding: 30px;
        text-align: center;
        box-shadow: 0 5px 20px rgba(0, 113, 113, 0.1);
        height: 100%;
        border-top: 4px solid var(--orbit-base);
        transition: all .3s;
      }

      .guarantee-card:hover {
        transform: translateY(-5px);
        border-top-color: var(--orbit-orange);
      }

      .guarantee-icon {
        width: 70px;
        height: 70px;
        background: linear-gradient(135deg, var(--orbit-pale), #d4f0f0);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
      }

      .guarantee-icon i {
        font-size: 30px;
        color: var(--orbit-dark);
      }

      .guarantee-card h4 {
        color: var(--orbit-dark);
        margin-bottom: 12px;
        font-size: 18px;
      }

      /* ===== TEAM ===== */
      .team-member .main-content span.category {
        color: var(--orbit-base);
      }

      .team-member .main-content ul li a {
        background: var(--orbit-pale);
        color: var(--orbit-dark);
      }

      .team-member .main-content ul li a:hover {
        background: var(--orbit-dark);
        color: #fff;
      }

      /* ===== TESTIMONIALS ===== */
      .testimonials {
        background: linear-gradient(135deg, var(--orbit-dark) 0%, var(--orbit-mid) 100%) !important;
      }

      .testimonials .item p {
        color: rgba(255, 255, 255, 0.9);
      }

      .testimonials .item span {
        color: var(--orbit-peach);
      }

      .testimonials .item h4 {
        color: #fff;
      }

      .testimonials .section-heading h6 {
        color: var(--orbit-peach) !important;
      }

      .testimonials .section-heading h2 {
        color: #fff;
      }

      .testimonials .section-heading p {
        color: rgba(255, 255, 255, 0.8);
      }

      .testimonials .owl-nav .owl-prev i,
      .testimonials .owl-nav .owl-next i {
        background: var(--orbit-orange);
        border-color: var(--orbit-orange);
        color: #fff;
      }

      .testimonials .owl-nav .owl-prev i:hover,
      .testimonials .owl-nav .owl-next i:hover {
        background: #fff;
        color: var(--orbit-dark);
      }

      /* ===== EVENTS/SCHEDULE ===== */
      .events .item {
        border-right: 4px solid var(--orbit-base);
        border-radius: 12px;
      }

      .events .item:hover {
        border-right-color: var(--orbit-orange);
      }

      .events .item ul li span.category {
        background: var(--orbit-light);
      }

      .events .item a {
        background: var(--orbit-base);
        color: #fff;
        border-radius: 50%;
      }

      .events .item a:hover {
        background: var(--orbit-orange);
      }

      /* ===== CONTACT ===== */
      .contact-us {
        background: var(--orbit-pale) !important;
      }

      .contact-us::before {
        background: linear-gradient(135deg, var(--orbit-dark) 0%, var(--orbit-base) 100%) !important;
      }

      .contact-us .section-heading h6 {
        color: var(--orbit-peach) !important;
      }

      .contact-us .section-heading h2 {
        color: #fff;
      }

      .contact-us .section-heading p {
        color: rgba(255, 255, 255, 0.85);
      }

      .special-offer-orbit {
        background: linear-gradient(135deg, var(--orbit-orange), var(--orbit-peach));
        border-radius: 16px;
        padding: 25px;
        color: #fff;
        margin-top: 20px;
      }

      .special-offer-orbit .festival-price {
        font-size: 32px;
        font-weight: 800;
        color: #fff;
      }

      .special-offer-orbit .original-price {
        font-size: 16px;
        text-decoration: line-through;
        color: rgba(255, 255, 255, 0.7);
      }

      .special-offer-orbit .discount-tag {
        background: var(--orbit-dark);
        color: #fff;
        border-radius: 12px;
        padding: 4px 14px;
        font-size: 13px;
        font-weight: 700;
        display: inline-block;
        margin-top: 8px;
      }

      #contact-form input,
      #contact-form textarea,
      #contact-form select {
        border: 2px solid rgba(0, 141, 141, 0.2) !important;
        border-radius: 10px !important;
        color: #333;
        transition: border-color .3s;
      }

      #contact-form input:focus,
      #contact-form textarea:focus,
      #contact-form select:focus {
        border-color: var(--orbit-base) !important;
        outline: none;
        box-shadow: 0 0 0 3px rgba(0, 188, 188, 0.15) !important;
      }

      #contact-form button {
        background: var(--orbit-orange) !important;
        color: #fff !important;
        border-radius: 25px !important;
        font-weight: 700 !important;
        height: auto !important;
        padding: 14px 35px !important;
        font-size: 16px !important;
        border: none !important;
        transition: all .3s !important;
        width: 100%;
      }

      #contact-form button:hover {
        background: var(--orbit-dark) !important;
        transform: translateY(-2px);
      }

      .contact-us-content {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 15px 40px rgba(0, 113, 113, 0.15);
      }

      /* ===== MODAL ===== */
      .modal-header {
        background: linear-gradient(135deg, var(--orbit-dark), var(--orbit-base));
        color: #fff;
        border-radius: 16px 16px 0 0;
      }

      .modal-header .btn-close {
        filter: invert(1);
      }

      .modal-title {
        color: #fff;
        font-weight: 700;
      }

      .modal-content {
        border-radius: 16px;
        border: none;
      }

      .modal-footer {
        border-top: 1px solid rgba(0, 141, 141, 0.15);
      }

      .btn-orbit-primary {
        background: var(--orbit-orange);
        color: #fff;
        border: none;
        border-radius: 25px;
        padding: 10px 28px;
        font-weight: 700;
        transition: all .3s;
      }

      .btn-orbit-primary:hover {
        background: var(--orbit-dark);
        color: #fff;
      }

      .btn-orbit-secondary {
        background: var(--orbit-pale);
        color: var(--orbit-dark);
        border: 2px solid var(--orbit-base);
        border-radius: 25px;
        padding: 10px 28px;
        font-weight: 600;
        transition: all .3s;
      }

      .btn-orbit-secondary:hover {
        background: var(--orbit-dark);
        color: #fff;
        border-color: var(--orbit-dark);
      }

      /* ===== FOOTER ===== */
      footer {
        background: linear-gradient(135deg, var(--orbit-dark), var(--orbit-mid)) !important;
      }

      footer p {
        color: rgba(255, 255, 255, 0.85) !important;
      }

      footer p a {
        color: var(--orbit-peach) !important;
      }

      footer p a:hover {
        color: #fff !important;
      }

      footer::before {
        background: transparent !important;
      }

      .footer-links a {
        color: rgba(255, 255, 255, 0.75);
        font-size: 14px;
        display: block;
        margin-bottom: 8px;
        transition: all .3s;
      }

      .footer-links a:hover {
        color: var(--orbit-peach);
        padding-right: 5px;
      }

      .footer-social a {
        display: inline-block;
        width: 38px;
        height: 38px;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 50%;
        line-height: 38px;
        text-align: center;
        color: #fff;
        margin-left: 8px;
        transition: all .3s;
      }

      .footer-social a:hover {
        background: var(--orbit-orange);
      }

      /* ===== ABOUT SECTION ===== */
      .about-us {
        background: #fff;
      }

      .about-us:before {
        background: linear-gradient(135deg, var(--orbit-pale) 0%, #d4f0f0 100%) !important;
      }

      .about-us .section-heading .main-button a {
        background: var(--orbit-orange);
        color: #fff;
      }

      .about-us .section-heading .main-button a:hover {
        background: var(--orbit-dark);
      }

      /* ===== ROADMAP SECTION ===== */
      .roadmap-section {
        padding: 80px 0;
        background: #fff;
      }

      .roadmap-card {
        background: var(--orbit-pale);
        border-radius: 20px;
        padding: 30px;
        text-align: center;
        border: 2px solid rgba(0, 188, 188, 0.2);
        transition: all .3s;
        height: 100%;
      }

      .roadmap-card:hover {
        background: linear-gradient(135deg, var(--orbit-pale), #c5eaea);
        border-color: var(--orbit-light);
        transform: translateY(-5px);
      }

      .roadmap-card.start-card {
        background: linear-gradient(135deg, var(--orbit-dark), var(--orbit-base));
        color: #fff;
        border-color: var(--orbit-orange);
      }

      .roadmap-card.start-card h4,
      .roadmap-card.start-card p,
      .roadmap-card.start-card span {
        color: #fff !important;
      }

      .roadmap-card.advanced-card {
        background: linear-gradient(135deg, var(--orbit-orange), var(--orbit-peach));
        color: #fff;
        border-color: var(--orbit-dark);
      }

      .roadmap-card.advanced-card h4,
      .roadmap-card.advanced-card p,
      .roadmap-card.advanced-card span {
        color: #fff !important;
      }

      .roadmap-card h4 {
