                                                                                                <script>
                                                                                                  // ===== CURRICULUM TABS =====
                                                                                                  function showTab(tabId, btn) {
                                                                                                  document.querySelectorAll('.curriculum-panel').forEach(p => p.classList.remove('active'));
                                                                                                  document.querySelectorAll('.curriculum-tab-btn').forEach(b => b.classList.remove('active'));
                                                                                                  document.getElementById('tab-' + tabId).classList.add('active');
                                                                                                  btn.classList.add('active');
                                                                                                  }

                                                                                                  // ===== CONTACT FORM SUBMISSION =====
                                                                                                  function submitForm(formEl, successEl, errorEl) {
                                                                                                  var token = formEl.querySelector('[name="__RequestVerificationToken"]').value;
                                                                                                  var name = formEl.querySelector('[name="Name"]').value.trim();
                                                                                                  var phone = formEl.querySelector('[name="Phone"]').value.trim();
                                                                                                  var subject = formEl.querySelector('[name="Subject"]').value;
                                                                                                  var message = (formEl.querySelector('[name="Message"]') || {}).value || '';

                                                                                                  if (!name || !phone || !subject) {
                                                                                                  errorEl.style.display = 'block';
                                                                                                  errorEl.textContent = 'لطفاً فیلدهای ستاره‌دار را پر کنید.';
                                                                                                  return;
                                                                                                  }
                                                                                                  errorEl.style.display = 'none';

                                                                                                  var formData = new FormData();
                                                                                                  formData.append('__RequestVerificationToken', token);
                                                                                                  formData.append('Name', name);
                                                                                                  formData.append('Phone', phone);
                                                                                                  formData.append('Subject', subject);
                                                                                                  formData.append('Message', message);

                                                                                                  var submitBtn = formEl.querySelector('button[type="submit"]') || document.getElementById('modal-submit-btn');
                                                                                                  if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'در حال ارسال...'; }

                                                                                                  fetch('/Contact/SubmitForm', {
                                                                                                  method: 'POST',
                                                                                                  headers: { 'RequestVerificationToken': token },
                                                                                                  body: formData
                                                                                                  })
                                                                                                  .then(function (r) { return r.json(); })
                                                                                                  .then(function (data) {
                                                                                                  if (data.success) {
                                                                                                  formEl.style.display = 'none';
                                                                                                  successEl.style.display = 'block';
                                                                                                  } else {
                                                                                                  errorEl.style.display = 'block';
                                                                                                  errorEl.textContent = data.message || 'خطایی رخ داده است.';
                                                                                                  }
                                                                                                  })
                                                                                                  .catch(function () {
                                                                                                  errorEl.style.display = 'block';
                                                                                                  errorEl.textContent = 'خطا در ارتباط با سرور. لطفاً بعداً تلاش کنید.';
                                                                                                  })
                                                                                                  .finally(function () {
                                                                                                  if (submitBtn) { submitBtn.disabled = false; }
                                                                                                  });
                                                                                                  }

                                                                                                  // Main contact form
                                                                                                  document.getElementById('contact-form').addEventListener('submit', function (e) {
                                                                                                  e.preventDefault();
                                                                                                  submitForm(this, document.getElementById('form-success'), document.getElementById('form-error'));
                                                                                                  });

                                                                                                  // Modal form submit
                                                                                                  document.getElementById('modal-submit-btn').addEventListener('click', function () {
                                                                                                  var form = document.getElementById('modal-contact-form');
                                                                                                  submitForm(form, document.getElementById('modal-form-success'), document.getElementById('modal-form-error'));
                                                                                                  });
                                                                                                </script>

